# Keycloak OAuth provider
# Realm issuer URL: https://auth.revsticks.ch/realms/revsticks
AUTH_KEYCLOAK_ISSUER="https://auth.revsticks.ch/realms/revsticks"
AUTH_KEYCLOAK_ID="your-keycloak-client-id"
AUTH_KEYCLOAK_SECRET="your-keycloak-client-secret"